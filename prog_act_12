# Activity 1
num1 = int(input("Enter a number: "))
num2 = int(input("Enter another number: "))

twoDList = []

for i in range(num1):
    twoDList.append([])

for i in range(1, num1+1):
    for j in range(1, num2+1):
        twoDList[i-1].append(i * j)
        
for i in range(num1):
    for j in range(num2):
        print(twoDList[i][j], end="   ")
    print()



